# CubeSat C2 — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# === Database ===
POSTGRES_USER=cubesat
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cubesat_c2
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379

# === NATS ===
NATS_URL=nats://nats:4222

# === Auth ===
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty in DEBUG=true mode to auto-generate an ephemeral secret.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# === SatNOGS ===
# API token: https://network.satnogs.org/users/apikey/
SATNOGS_API_TOKEN=

# === Celestrak / TLE ===
# No token needed for public TLEs
TLE_SOURCE_URL=https://celestrak.org/SOCRATES/query.php

# === App ===
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# === Grafana ===
GRAFANA_PASSWORD=admin

# === Cesium ===
VITE_CESIUM_TOKEN=your-cesium-ion-token-here
